{
  "name": "pesos",
  "version": "0.1.1",
  "private": true,
  "author": {
    "name": "getodevel",
    "email": "getodevel@proton.me"
  },
  "main": "electron.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "electron": "electron .",
    "electron-pack": "electron-builder"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "better-sqlite3": "^12.11.1",
    "lucide-react": "^1.18.0",
    "next": "16.2.9",
    "openai": "^6.45.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.9"
  },
  "build": {
    "appId": "com.getodevel.pesos",
    "productName": "PESOS",
    "files": [
      "**/*",
      "!.next/cache/**/*",
      "!node_modules/electron/**/*",
      "!node_modules/electron-builder/**/*"
    ],
    "asar": false,
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "public/logo.png"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "public/logo.png",
      "category": "Office"
    },
    "deb": {
      "depends": ["libglib2.0-0", "libnss3", "libatk1.0-0", "libatk-bridge2.0-0", "libx11-6"]
    },
    "mac": {
      "target": "zip",
      "icon": "public/logo.png"
    }
  }
}
